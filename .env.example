CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_DB=default

# HDFS container config (consumed by bde2020 namenode/datanode entrypoint)
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
HDFS_CONF_dfs_replication=1
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false
HDFS_CONF_dfs_permissions_enabled=false

# Per-user overrides — run `make init-user` to auto-generate .env.local,
# or create it manually with the values below (customized for your username):
# COMPOSE_PROJECT_NAME=yourname_clickhouse
# CH_HTTP_PORT=8123
# CH_NATIVE_PORT=9000
# CH_DATA_DIR=./clickhouse-data-yourname
